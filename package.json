{
  "name": "QuickDraw",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "check-types": "turbo check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "eslint": "^9.39.2",
    "prettier": "^3.4.2",
    "turbo": "^2.4.0",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": "^20.0.0 || ^22.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.8",
      "@types/react-dom": "19.0.3",
      "minimatch": ">=9.0.6",
      "glob": ">=10.4.3",
      "@babel/core": ">=7.29.6",
      "path-to-regexp": ">=0.1.13",
      "qs": ">=6.15.2",
      "form-data": ">=4.0.6",
      "js-cookie": ">=3.0.7",
      "dompurify": ">=3.4.11",
      "postcss": ">=8.5.10",
      "picomatch@2": ">=2.3.2",
      "picomatch@4": ">=4.0.4"
    }
  }
}